################################################################################
# WHITELIST - Některé soubory JSOU důležité a nesmějí se ignorovat!
#
# Pokud máš soubor který normálně ignorujeme ale potřebuješ ho pushit,
# můžeš to udělat tímto způsobem:
#
#   git add -f important_file.xlsx
#   git commit -m "Add important file"
#   git push origin main
#
# Nebo zaměň řádek v gitignore na:
#   !important_file.xlsx
################################################################################

# Příklady whitelist (odkomentuj pokud potřebuješ):
# !.env.example
# !.vscode/settings.json
# !requirements-dev.txt

